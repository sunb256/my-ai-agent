{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug main prompt",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "args": ["Say hello briefly"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "0"
      }
    },
    {
      "name": "Debug main REPL",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "0"
      }
    },
    {
      "name": "Debug pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYDEVD_USE_SYS_MONITORING": "0"
      }
    }
  ]
}
