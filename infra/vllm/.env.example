# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=vllm-monitoring

# -----------------------------------------------------------------------------
# vLLM image and model
# -----------------------------------------------------------------------------
# 本番では検証済みバージョンに固定してください。
VLLM_IMAGE=vllm/vllm-openai:v0.25.0

# 動作確認用の軽量モデルです。実運用モデルへ変更してください。
VLLM_MODEL=Qwen/Qwen3-0.6B
VLLM_SERVED_MODEL_NAME=local-model

# Hugging Faceの認証が必要なモデルのみ設定します。
HF_TOKEN=
HF_CACHE_DIR=./data/huggingface

# -----------------------------------------------------------------------------
# vLLM API
# -----------------------------------------------------------------------------
# LANへ直接公開せず、通常はFastAPIやリバースプロキシ経由にします。
VLLM_BIND_ADDRESS=127.0.0.1
VLLM_HOST_PORT=8000

# 必ず長いランダム文字列へ変更してください。
VLLM_API_KEY=change-this-to-a-long-random-string

# -----------------------------------------------------------------------------
# GPU / model execution
# -----------------------------------------------------------------------------
# 複数GPUを使う場合は例: 0,1
# 空欄ならvLLMへ --device-ids を渡しません。
VLLM_DEVICE_IDS=0

# 使用GPU数に合わせます。単一GPUなら1、2GPUなら2。
VLLM_TENSOR_PARALLEL_SIZE=1

# GPUメモリ全体のうちvLLMインスタンスが利用する割合。
VLLM_GPU_MEMORY_UTILIZATION=0.90

VLLM_DTYPE=auto
VLLM_KV_CACHE_DTYPE=auto

# 空欄ならモデル既定値・vLLM自動設定を使用します。
# 24GB GPUで最初に試す場合は8192程度から始めると調整しやすいです。
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=
VLLM_MAX_NUM_BATCHED_TOKENS=
VLLM_QUANTIZATION=
VLLM_CPU_OFFLOAD_GB=0

# -----------------------------------------------------------------------------
# Cache and model behavior
# -----------------------------------------------------------------------------
VLLM_ENABLE_PREFIX_CACHING=true
VLLM_TRUST_REMOTE_CODE=false

# 追加引数が必要な場合に使用します。単純な空白区切りです。
# 例: VLLM_EXTRA_ARGS=--enforce-eager
VLLM_EXTRA_ARGS=

# 高頻度な監視アクセスをvLLMのアクセスログから除外します。
VLLM_DISABLE_ACCESS_LOG_FOR_ENDPOINTS=/health,/metrics,/ping

# -----------------------------------------------------------------------------
# Container operation
# -----------------------------------------------------------------------------
VLLM_SHM_SIZE=16gb
VLLM_HEALTH_INTERVAL=15s
VLLM_HEALTH_TIMEOUT=10s
VLLM_HEALTH_RETRIES=10
VLLM_HEALTH_START_PERIOD=10m
VLLM_LOG_MAX_SIZE=50m
VLLM_LOG_MAX_FILES=3

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HOST_PORT=9090
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=10GB
PROMETHEUS_LOG_MAX_SIZE=20m
PROMETHEUS_LOG_MAX_FILES=3
